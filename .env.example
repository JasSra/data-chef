# ═══════════════════════════════════════════════════════════════════════════
# Data Chef - Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and configure the values below:
#   cp .env.example .env
#
# Then uncomment `env_file:` in docker-compose.yml to load it.
#
# ═══════════════════════════════════════════════════════════════════════════

# ┌───────────────────────────────────────────────────────────────────────────
# │ REQUIRED - Encryption Key
# └───────────────────────────────────────────────────────────────────────────
# This key encrypts sensitive credentials (API keys, passwords, OAuth tokens)
# stored in connector configurations.
#
# Generate a secure key:
#   openssl rand -base64 32
#   OR
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# ⚠️  CRITICAL:
#   - Never commit this to git
#   - Use the same key across all container instances
#   - If lost, all encrypted credentials become unrecoverable
#   - Store in a vault (Azure Key Vault, AWS Secrets Manager, etc.)
#
CONNECTOR_SECRET_KEY=

# ┌───────────────────────────────────────────────────────────────────────────
# │ OPTIONAL - OpenTelemetry (OTEL) Distributed Tracing & Metrics
# └───────────────────────────────────────────────────────────────────────────
# Enable distributed tracing and metrics export to your observability backend.
# 
# Auto-instruments: HTTP, PostgreSQL, MySQL, MongoDB, Redis, Next.js
#
# OTEL_ENABLED=true
# OTEL_SERVICE_NAME=data-chef
#
# ── For production with your own OTEL collector: ──
# OTEL_EXPORTER_OTLP_ENDPOINT=http://your-otel-collector.threadcode.internal:4318
# OTEL_EXPORTER_OTLP_HEADERS=x-api-key=your-observability-api-key
#
# ── Alternative backends (choose one): ──
# Jaeger:      http://jaeger:4318
# Tempo:       http://tempo:4318
# Honeycomb:   https://api.honeycomb.io (add x-honeycomb-team header)
# New Relic:   https://otlp.nr-data.net:4318 (add api-key header)
# Datadog:     http://datadog-agent:4318
# Azure Monitor: Set APPLICATIONINSIGHTS_CONNECTION_STRING instead

# ┌───────────────────────────────────────────────────────────────────────────
# │ OPTIONAL - Azure App Insights / Azure Monitor Connector
# └───────────────────────────────────────────────────────────────────────────
# Pre-configure an Azure observability connector on startup.
# You can also add connectors via the UI without these env vars.
#
# APPINSIGHTS_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# APPINSIGHTS_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# APPINSIGHTS_CLIENT_SECRET=your-client-secret-value
#
# ── For Azure Monitor / Log Analytics (recommended): ──
# APPINSIGHTS_WORKSPACE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
#
# ── For legacy App Insights API (classic resources only): ──
# APPINSIGHTS_APP_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ┌───────────────────────────────────────────────────────────────────────────
# │ OPTIONAL - External Shared Redis
# └───────────────────────────────────────────────────────────────────────────
# If using a centralized shared Redis cluster (e.g., for multi-instance setup)
# instead of managing Redis via the connector UI.
#
# REDIS_HOST=redis.threadcode.internal
# REDIS_PORT=6379
# REDIS_PASSWORD=your-redis-password
# REDIS_TLS=true
# REDIS_DB=0

# ┌───────────────────────────────────────────────────────────────────────────
# │ OPTIONAL - Database Connections (for connectors)
# └───────────────────────────────────────────────────────────────────────────
# Pre-configure database connectors via environment variables.
# Alternatively, configure via the UI at runtime.
#
# SQL Server (MSSQL):
# When running in Docker, defaults to 'host.docker.internal' to reach host machine
# Override the default host for SQL Server connectors:
# MSSQL_DEFAULT_HOST=192.168.4.102
# MSSQL_DEFAULT_HOST=host.docker.internal
# MSSQL_DEFAULT_HOST=sqlserver.local
#
# PostgreSQL:
# POSTGRES_HOST=postgres.threadcode.internal
# POSTGRES_PORT=5432
# POSTGRES_USER=datachef
# POSTGRES_PASSWORD=your-postgres-password
# POSTGRES_DATABASE=analytics
#
# MySQL:
# MYSQL_HOST=mysql.threadcode.internal
# MYSQL_PORT=3306
# MYSQL_USER=datachef
# MYSQL_PASSWORD=your-mysql-password
# MYSQL_DATABASE=analytics
#
# MongoDB:
# MONGODB_URI=mongodb://datachef:password@mongo.threadcode.internal:27017/analytics

# ┌───────────────────────────────────────────────────────────────────────────
# │ OPTIONAL - GitHub OAuth (for GitHub connector)
# └───────────────────────────────────────────────────────────────────────────
# GITHUB_CLIENT_ID=Iv1.xxxxxxxxxxxxxxxx
# GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ┌───────────────────────────────────────────────────────────────────────────
# │ OPTIONAL - Azure DevOps OAuth (for Azure DevOps connector)
# └───────────────────────────────────────────────────────────────────────────
# AZUREDEVOPS_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# AZUREDEVOPS_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AZUREDEVOPS_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ┌───────────────────────────────────────────────────────────────────────────
# │ OPTIONAL - Runtime Configuration
# └───────────────────────────────────────────────────────────────────────────
# NODE_ENV=production
# PORT=3000
# LOG_LEVEL=info
# TZ=UTC

# ┌───────────────────────────────────────────────────────────────────────────
# │ Summary - What You Need for Production
# └───────────────────────────────────────────────────────────────────────────
# REQUIRED:
#   1. CONNECTOR_SECRET_KEY (generate with: openssl rand -base64 32)
#
# RECOMMENDED:
#   2. OTEL_ENABLED=true (for observability)
#   3. OTEL_EXPORTER_OTLP_ENDPOINT=http://your-otel-collector:4318
#   4. Volume mount: /app/.datachef (for data persistence)
#
# OPTIONAL (if using shared infrastructure):
#   5. REDIS_HOST, REDIS_PASSWORD (if using external Redis)
#   6. Database connection strings (if pre-configuring connectors)
#   7. OAuth credentials (for GitHub, Azure DevOps connectors)

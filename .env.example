# dataChef — optional environment variables
#
# Copy this file to .env and fill in values, then uncomment `env_file`
# in docker-compose.yml to load it.
#
#   cp .env.example .env
#
# The app starts with zero configuration — these are only needed to
# pre-configure the App Insights connector at boot time.  You can also
# add connectors interactively through the UI without any env vars.

# ── Azure App Insights / Azure Monitor (optional) ───────────────────────────
# APPINSIGHTS_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# APPINSIGHTS_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# APPINSIGHTS_CLIENT_SECRET=your-client-secret-value

# For Azure Monitor / Log Analytics (recommended — workspace-based resources)
# APPINSIGHTS_WORKSPACE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# For legacy App Insights API (classic resources only)
# APPINSIGHTS_APP_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
